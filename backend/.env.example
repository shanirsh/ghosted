# OpenAI API
OPENAI_API_KEY=your_openai_api_key

# Backend
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# AWS defaults. User-specific Role ARN, External ID, and Region are entered in the UI.
AWS_REGION=us-east-1

# Optional local-development secret for integrations that need one.
SECRET_KEY=change-me
